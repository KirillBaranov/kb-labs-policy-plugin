{
  "name": "@kb-labs/policy-core",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Core implementation for KB Labs policy plugin. Category resolver, policy runner, and checks.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-manifest": {
      "import": "./dist/manifest.v3.js",
      "types": "./dist/manifest.v3.d.ts"
    },
    "./cli": "./dist/cli/index.js",
    "./core": "./dist/core/index.js",
    "./dist/*": "./dist/*"
  },
  "kb": {
    "manifest": "./dist/manifest.v3.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kb-labs/policy-contracts": "link:../policy-contracts",
    "@kb-labs/sdk": "link:../../../../platform/kb-labs-sdk/packages/sdk",
    "semver": "^7.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit",
    "@types/node": "^24.3.3",
    "@types/semver": "^7.5.8",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}